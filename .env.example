# ============================================================================
# claude-context-plane — configuration
# ============================================================================
# Copy this file to .env and fill in your TiDB Cloud Essentials credentials.
# Get them from: https://tidbcloud.com/console/clusters -> your cluster -> Connect
# ============================================================================

# --- TiDB connection ---
TIDB_HOST=gateway01.<region>.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=<prefix>.root
TIDB_PASSWORD=<password>
TIDB_DATABASE=claude_context

# Path to the TiDB CA bundle (download from the TiDB Cloud console "Connect" dialog).
# Required for TLS on most Essentials / Starter deployments.
# TIDB_SSL_CA=/etc/ssl/cert.pem

# --- Embedding model ---
# Default: no API key needed, hosted by TiDB Cloud. 1024-dim.
EMBEDDING_MODEL=tidbcloud_free/amazon/titan-embed-text-v2

# Alternative (HuggingFace BYOK — requires HF API key and may be region-limited):
# EMBEDDING_MODEL=huggingface/sentence-transformers/all-MiniLM-L6-v2
# Note: switching the embedding model also changes the vector dimension.
# You MUST drop and recreate the tables if you change this after first use.
